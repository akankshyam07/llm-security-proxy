# Application settings
APP_NAME=llm-security-proxy
ENVIRONMENT=development
UPSTREAM_BASE_URL=http://localhost:11434
UPSTREAM_PATH=/v1/chat/completions
REQUEST_TIMEOUT=120
LOG_LEVEL=INFO
POLICY_PATH=app/policies/default_policy.yaml

# Comma-separated tool allowlist override (empty = use policy file; set to enforce at runtime)
ALLOWED_TOOLS=

# Enable scanning of upstream responses (true/false). Off by default — adds latency.
ENABLE_OUTPUT_DETECTION=false
