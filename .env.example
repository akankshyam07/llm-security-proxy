# Application settings
APP_NAME=llm-security-proxy
ENVIRONMENT=development
UPSTREAM_BASE_URL=http://localhost:11434
UPSTREAM_PATH=/v1/chat/completions
REQUEST_TIMEOUT=120
LOG_LEVEL=INFO
POLICY_PATH=app/policies/default_policy.yaml
# Comma separated tool allowlist override
ALLOWED_TOOLS=
# Enable output detection (true/false)
ENABLE_OUTPUT_DETECTION=false
